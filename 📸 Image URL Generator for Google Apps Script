// ============================================================
// CONFIGURAR TRIGGERS AUTOMÁTICOS
// ============================================================

function configurarTriggers() {
  // Limpiar triggers existentes
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === 'procesarTodasLasImagenes') {
      ScriptApp.deleteTrigger(triggers[i]);
    }
  }
  
  if (INTERVALO_HORAS > 0) {
    ScriptApp.newTrigger('procesarTodasLasImagenes')
        .timeBased()
        .everyHours(INTERVALO_HORAS)
        .create();
    console.log(`✅ Trigger configurado cada ${INTERVALO_HORAS} horas`);
  } else {
    console.log("⚠️ Triggers desactivados (INTERVALO_HORAS = 0)");
  }
}

